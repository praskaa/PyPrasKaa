<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Graphic Override Configurator"
    Width="380" Height="520"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen"
    Background="#2D2D2D"
    Foreground="#EEEEEE"
    FontFamily="Segoe UI"
    FontSize="11">

    <Window.Resources>
        <!-- Base TextBlock style -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <!-- Label-like TextBlock -->
        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- ComboBox style -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#1E1E1E"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="#1E1E1E"/>
                        <Setter Property="Background" Value="#FFFFFF"/>
                        <Setter Property="FontSize" Value="11"/>
                        <Setter Property="FontFamily" Value="Segoe UI"/>
                        <Setter Property="Padding" Value="6,3"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#CCE4F7"/>
                                <Setter Property="Foreground" Value="#000000"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#CCE4F7"/>
                                <Setter Property="Foreground" Value="#000000"/>
                            </Trigger>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" Value="#CCE4F7"/>
                                <Setter Property="Foreground" Value="#000000"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TextBox style (value display) -->
        <Style x:Key="ValueBox" TargetType="TextBox">
            <Setter Property="Background" Value="#3F3F46"/>
            <Setter Property="Foreground" Value="#EEEEEE"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Segoe UI Mono, Consolas"/>
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <!-- Slider style -->
        <Style TargetType="Slider">
            <Setter Property="Minimum" Value="0"/>
            <Setter Property="Maximum" Value="255"/>
            <Setter Property="SmallChange" Value="1"/>
            <Setter Property="LargeChange" Value="10"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="#0078D7"/>
        </Style>

        <!-- GroupBox style -->
        <Style TargetType="GroupBox">
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="8,6,8,6"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>

        <!-- CheckBox style -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#EEEEEE"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Primary button -->
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background" Value="#0078D7"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#0078D7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="MinWidth" Value="75"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1C86EE"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Secondary button -->
        <Style x:Key="BtnSecondary" TargetType="Button">
            <Setter Property="Background" Value="#3E3E42"/>
            <Setter Property="Foreground" Value="#EEEEEE"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="MinWidth" Value="75"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#45454A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Palette icon button -->
        <Style x:Key="BtnPalette" TargetType="Button">
            <Setter Property="Background" Value="#3E3E42"/>
            <Setter Property="Foreground" Value="#EEEEEE"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Width" Value="26"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#45454A"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="12,10,12,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Fill Pattern -->
        <StackPanel Grid.Row="0" Margin="0,0,0,6">
            <TextBlock Text="Fill Pattern" Margin="0,0,0,3"/>
            <ComboBox x:Name="PatternComboBox"/>
        </StackPanel>

        <!-- Foreground GroupBox -->
        <GroupBox Grid.Row="1" Header="Foreground Color">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="36"/>
                </Grid.ColumnDefinitions>

                <!-- R -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="R" Style="{StaticResource LabelText}" Margin="0,0,4,3"/>
                <Slider   Grid.Row="0" Grid.Column="1" x:Name="FgR" Margin="0,0,6,3"/>
                <TextBox  Grid.Row="0" Grid.Column="2" x:Name="FgRVal" Style="{StaticResource ValueBox}" Margin="0,0,0,3"/>

                <!-- G -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="G" Style="{StaticResource LabelText}" Margin="0,0,4,3"/>
                <Slider   Grid.Row="1" Grid.Column="1" x:Name="FgG" Margin="0,0,6,3"/>
                <TextBox  Grid.Row="1" Grid.Column="2" x:Name="FgGVal" Style="{StaticResource ValueBox}" Margin="0,0,0,3"/>

                <!-- B -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="B" Style="{StaticResource LabelText}" Margin="0,0,4,3"/>
                <Slider   Grid.Row="2" Grid.Column="1" x:Name="FgB" Margin="0,0,6,3"/>
                <TextBox  Grid.Row="2" Grid.Column="2" x:Name="FgBVal" Style="{StaticResource ValueBox}" Margin="0,0,0,3"/>

                <!-- Preview + palette button -->
                <Grid Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border x:Name="FgPreview" Grid.Column="0"
                            Height="24" BorderBrush="#555555" BorderThickness="1"
                            Background="#808080"/>
                    <Button Grid.Column="1" x:Name="FgPaletteButton"
                            Style="{StaticResource BtnPalette}"
                            Margin="4,0,0,0"
                            Content="&#x1F3A8;"
                            ToolTip="Pick from palette"/>
                </Grid>
            </Grid>
        </GroupBox>

        <!-- Background GroupBox -->
        <GroupBox Grid.Row="2" Header="Background Color">
            <StackPanel>
                <CheckBox x:Name="BgEnabled" Content="Enable Background Override"
                          IsChecked="True" Margin="0,0,0,6"/>
                <Grid x:Name="BgControls">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="36"/>
                    </Grid.ColumnDefinitions>

                    <!-- R -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="R" Style="{StaticResource LabelText}" Margin="0,0,4,3"/>
                    <Slider   Grid.Row="0" Grid.Column="1" x:Name="BgR" Margin="0,0,6,3"/>
                    <TextBox  Grid.Row="0" Grid.Column="2" x:Name="BgRVal" Style="{StaticResource ValueBox}" Margin="0,0,0,3"/>

                    <!-- G -->
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="G" Style="{StaticResource LabelText}" Margin="0,0,4,3"/>
                    <Slider   Grid.Row="1" Grid.Column="1" x:Name="BgG" Margin="0,0,6,3"/>
                    <TextBox  Grid.Row="1" Grid.Column="2" x:Name="BgGVal" Style="{StaticResource ValueBox}" Margin="0,0,0,3"/>

                    <!-- B -->
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="B" Style="{StaticResource LabelText}" Margin="0,0,4,3"/>
                    <Slider   Grid.Row="2" Grid.Column="1" x:Name="BgB" Margin="0,0,6,3"/>
                    <TextBox  Grid.Row="2" Grid.Column="2" x:Name="BgBVal" Style="{StaticResource ValueBox}" Margin="0,0,0,3"/>

                    <!-- Preview + palette button -->
                    <Grid Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border x:Name="BgPreview" Grid.Column="0"
                                Height="24" BorderBrush="#555555" BorderThickness="1"
                                Background="#B4B4B4"/>
                        <Button Grid.Column="1" x:Name="BgPaletteButton"
                                Style="{StaticResource BtnPalette}"
                                Margin="4,0,0,0"
                                Content="&#x1F3A8;"
                                ToolTip="Pick from palette"/>
                    </Grid>
                </Grid>
            </StackPanel>
        </GroupBox>

        <!-- Spacer -->
        <Grid Grid.Row="3"/>

        <!-- Footer buttons -->
        <Border Grid.Row="4" BorderBrush="#444444" BorderThickness="0,1,0,0" Padding="0,8,0,0" Margin="0,8,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="CancelButton" Content="Cancel"
                        Style="{StaticResource BtnSecondary}" Margin="0,0,8,0"/>
                <Button x:Name="OkButton"     Content="OK"
                        Style="{StaticResource BtnPrimary}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
