<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Choose Color"
    Width="320" Height="420"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterOwner"
    Background="#131313"
    Foreground="#E4E2E1"
    FontFamily="Segoe UI"
    FontSize="11">

    <Window.Resources>
        <!-- Swatch button base style -->
        <Style x:Key="SwatchBtn" TargetType="Button">
            <Setter Property="Width"  Value="44"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="SwatchBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2">
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SwatchBorder" Property="BorderBrush" Value="#9FCAFF"/>
                                <Setter TargetName="SwatchBorder" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Footer primary -->
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background" Value="#007ACC"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#006BB3"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Footer secondary -->
        <Style x:Key="BtnSecondary" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#9B9B9B"/>
            <Setter Property="BorderBrush" Value="#404751"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#353535"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>   <!-- Header bar -->
            <RowDefinition Height="*"/>    <!-- Content -->
            <RowDefinition Height="Auto"/> <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- Header bar -->
        <Border Grid.Row="0" Background="#1B1C1C">
            <Grid Margin="12,0">
                <TextBlock Text="CHOOSE COLOR PALETTE"
                           FontSize="10" FontWeight="Bold"
                           Foreground="#E4E2E1"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="14,12,14,8">

                <!-- Active selection preview -->
                <Border Background="#1F2020" Padding="8" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="52"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border x:Name="SelectedSwatch" Grid.Column="0"
                                Width="44" Height="44"
                                Background="#9FCAFF"
                                CornerRadius="2"/>
                        <StackPanel Grid.Column="1" Margin="10,0,0,0"
                                    VerticalAlignment="Center">
                            <TextBlock Text="ACTIVE SELECTION"
                                       FontSize="9" FontWeight="Bold"
                                       Foreground="#C0C7D3"
                                       Margin="0,0,0,4"/>
                            <TextBlock x:Name="SelectedHexLabel"
                                       Text="#9FCAFF"
                                       FontFamily="Consolas"
                                       FontSize="12"
                                       Foreground="#E4E2E1"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Section label -->
                <StackPanel Margin="0,0,0,6">
                    <TextBlock Text="Material Library"
                               FontSize="10" FontWeight="Medium"
                               Foreground="#C0C7D3"/>
                    <Rectangle Height="1" Fill="#007ACC" Width="28"
                               HorizontalAlignment="Left" Margin="0,3,0,0"/>
                </StackPanel>

                <!-- Swatch grid: 4 columns -->
                <Border Background="#1F2020" Padding="8">
                    <UniformGrid x:Name="ColorGrid" Columns="4" Rows="4">
                        <!-- Row 1 -->
                        <Button Style="{StaticResource SwatchBtn}" Background="#F44336" Tag="#F44336" ToolTip="Red"/>
                        <Button Style="{StaticResource SwatchBtn}" Background="#E91E63" Tag="#E91E63" ToolTip="Pink"/>
                        <Button Style="{StaticResource SwatchBtn}" Background="#9C27B0" Tag="#9C27B0" ToolTip="Purple"/>
                        <Button Style="{StaticResource SwatchBtn}" Background="#673AB7" Tag="#673AB7" ToolTip="Deep Purple"/>
                        <!-- Row 2 -->
                        <Button Style="{StaticResource SwatchBtn}" Background="#3F51B5" Tag="#3F51B5" ToolTip="Indigo"/>
                        <Button Style="{StaticResource SwatchBtn}" Background="#2196F3" Tag="#2196F3" ToolTip="Blue"/>
                        <Button Style="{StaticResource SwatchBtn}" Background="#03A9F4" Tag="#03A9F4" ToolTip="Light Blue"/>
                        <Button Style="{StaticResource SwatchBtn}" Background="#00BCD4" Tag="#00BCD4" ToolTip="Cyan"/>
                        <!-- Row 3 -->
                        <Button Style="{StaticResource SwatchBtn}" Background="#009688" Tag="#009688" ToolTip="Teal"/>
                        <Button Style="{StaticResource SwatchBtn}" Background="#4CAF50" Tag="#4CAF50" ToolTip="Green"/>
                        <Button Style="{StaticResource SwatchBtn}" Background="#8BC34A" Tag="#8BC34A" ToolTip="Light Green"/>
                        <Button Style="{StaticResource SwatchBtn}" Background="#CDDC39" Tag="#CDDC39" ToolTip="Lime"/>
                        <!-- Row 4 -->
                        <Button Style="{StaticResource SwatchBtn}" Background="#FFEB3B" Tag="#FFEB3B" ToolTip="Yellow"/>
                        <Button Style="{StaticResource SwatchBtn}" Background="#FFC107" Tag="#FFC107" ToolTip="Amber"/>
                        <Button Style="{StaticResource SwatchBtn}" Background="#FF9800" Tag="#FF9800" ToolTip="Orange"/>
                        <Button Style="{StaticResource SwatchBtn}" Background="#FF5722" Tag="#FF5722" ToolTip="Deep Orange"/>
                    </UniformGrid>
                </Border>

                <!-- Extra neutral row -->
                <Border Background="#1F2020" Padding="8" Margin="0,2,0,0">
                    <UniformGrid Columns="4" Rows="1">
                        <Button Style="{StaticResource SwatchBtn}" Background="#FFFFFF" Tag="#FFFFFF" ToolTip="White"/>
                        <Button Style="{StaticResource SwatchBtn}" Background="#B4B4B4" Tag="#B4B4B4" ToolTip="Light Grey"/>
                        <Button Style="{StaticResource SwatchBtn}" Background="#808080" Tag="#808080" ToolTip="Grey"/>
                        <Button Style="{StaticResource SwatchBtn}" Background="#1E1E1E" Tag="#1E1E1E" ToolTip="Near Black"/>
                    </UniformGrid>
                </Border>

                <!-- Pick Custom (ColorDialog) -->
                <Button x:Name="PickCustomButton"
                        Margin="0,8,0,0"
                        Height="32"
                        Background="#2A2A2A"
                        Foreground="#E4E2E1"
                        BorderBrush="#404751"
                        BorderThickness="1"
                        Cursor="Hand"
                        ToolTip="Open Windows color picker">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#9678;" FontSize="13" Margin="0,0,6,0"
                                   Foreground="#9FCAFF" VerticalAlignment="Center"/>
                        <TextBlock Text="PICK CUSTOM" FontSize="10" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Padding="14,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="SelectButton" Grid.Column="0"
                        Content="SELECT"
                        Style="{StaticResource BtnPrimary}"/>
                <Button x:Name="CancelButton" Grid.Column="2"
                        Content="CANCEL"
                        Style="{StaticResource BtnSecondary}"/>
            </Grid>
        </Border>
    </Grid>
</Window>
