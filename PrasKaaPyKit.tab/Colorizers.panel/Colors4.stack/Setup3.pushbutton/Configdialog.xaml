<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Graphic Override Configurator"
    Width="420" Height="620"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen"
    Background="#2D2D2D"
    Foreground="#EEEEEE"
    FontFamily="Segoe UI"
    FontSize="11">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#1E1E1E"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="#1E1E1E"/>
                        <Setter Property="Background" Value="#FFFFFF"/>
                        <Setter Property="FontSize" Value="11"/>
                        <Setter Property="FontFamily" Value="Segoe UI"/>
                        <Setter Property="Padding" Value="6,3"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#CCE4F7"/>
                                <Setter Property="Foreground" Value="#000000"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#CCE4F7"/>
                                <Setter Property="Foreground" Value="#000000"/>
                            </Trigger>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" Value="#CCE4F7"/>
                                <Setter Property="Foreground" Value="#000000"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ValueBox" TargetType="TextBox">
            <Setter Property="Background" Value="#3F3F46"/>
            <Setter Property="Foreground" Value="#EEEEEE"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Segoe UI Mono, Consolas"/>
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        <Style TargetType="Slider">
            <Setter Property="Minimum" Value="0"/>
            <Setter Property="Maximum" Value="255"/>
            <Setter Property="SmallChange" Value="1"/>
            <Setter Property="LargeChange" Value="10"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="#0078D7"/>
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="8,6,8,6"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#EEEEEE"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background" Value="#0078D7"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#0078D7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="MinWidth" Value="75"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1C86EE"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="BtnSecondary" TargetType="Button">
            <Setter Property="Background" Value="#3E3E42"/>
            <Setter Property="Foreground" Value="#EEEEEE"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="MinWidth" Value="75"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#45454A"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="BtnPalette" TargetType="Button">
            <Setter Property="Background" Value="#3E3E42"/>
            <Setter Property="Foreground" Value="#EEEEEE"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Width" Value="26"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#45454A"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="12,10,12,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Fill Pattern -->
            <StackPanel Grid.Row="0" Margin="0,0,0,6">
                <TextBlock Text="Fill Pattern (Surface FG &amp; BG)" Margin="0,0,0,3"/>
                <ComboBox x:Name="PatternComboBox"/>
            </StackPanel>

            <!-- Projection Lines -->
            <GroupBox Grid.Row="1" Header="Projection Lines">
                <StackPanel>
                    <CheckBox x:Name="ProjEnabled" Content="Enable Projection Override" IsChecked="True"/>
                    <StackPanel x:Name="ProjControls" Margin="12,4,0,0">
                        <CheckBox x:Name="ProjOverridePattern" Content="Override Pattern" IsChecked="True"/>
                        <StackPanel x:Name="ProjPatternRow" Orientation="Horizontal" Margin="12,2,0,2">
                            <TextBlock Text="Pattern:" Style="{StaticResource LabelText}" Margin="0,0,6,0"/>
                            <ComboBox x:Name="ProjPatternComboBox" Width="140"/>
                        </StackPanel>
                        <CheckBox x:Name="ProjOverrideWeight" Content="Override Weight" IsChecked="True"/>
                        <StackPanel x:Name="ProjWeightRow" Orientation="Horizontal" Margin="12,2,0,2">
                            <TextBlock Text="Weight:" Style="{StaticResource LabelText}" Margin="0,0,6,0"/>
                            <ComboBox x:Name="ProjWeight" Width="60"/>
                        </StackPanel>
                        <CheckBox x:Name="ProjOverrideColor" Content="Override Color" IsChecked="True"/>
                        <Grid x:Name="ProjColorRow" Margin="12,2,0,2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="36"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="R" Style="{StaticResource LabelText}" Margin="0,0,4,2"/>
                            <Slider Grid.Row="0" Grid.Column="1" x:Name="ProjR" Margin="0,0,6,2"/>
                            <TextBox Grid.Row="0" Grid.Column="2" x:Name="ProjRVal" Style="{StaticResource ValueBox}" Margin="0,0,0,2"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="G" Style="{StaticResource LabelText}" Margin="0,0,4,2"/>
                            <Slider Grid.Row="1" Grid.Column="1" x:Name="ProjG" Margin="0,0,6,2"/>
                            <TextBox Grid.Row="1" Grid.Column="2" x:Name="ProjGVal" Style="{StaticResource ValueBox}" Margin="0,0,0,2"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="B" Style="{StaticResource LabelText}" Margin="0,0,4,2"/>
                            <Slider Grid.Row="2" Grid.Column="1" x:Name="ProjB" Margin="0,0,6,2"/>
                            <TextBox Grid.Row="2" Grid.Column="2" x:Name="ProjBVal" Style="{StaticResource ValueBox}" Margin="0,0,0,2"/>
                            <Grid Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,2,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border x:Name="ProjPreview" Grid.Column="0" Height="20" BorderBrush="#555555" BorderThickness="1" Background="#000000"/>
                                <Button Grid.Column="1" x:Name="ProjPaletteButton" Style="{StaticResource BtnPalette}" Margin="4,0,0,0" Content="&#x1F3A8;" ToolTip="Pick from palette"/>
                            </Grid>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <!-- Cut Lines -->
            <GroupBox Grid.Row="2" Header="Cut Lines">
                <StackPanel>
                    <CheckBox x:Name="CutEnabled" Content="Enable Cut Override" IsChecked="True"/>
                    <StackPanel x:Name="CutControls" Margin="12,4,0,0">
                        <CheckBox x:Name="CutOverridePattern" Content="Override Pattern" IsChecked="True"/>
                        <StackPanel x:Name="CutPatternRow" Orientation="Horizontal" Margin="12,2,0,2">
                            <TextBlock Text="Pattern:" Style="{StaticResource LabelText}" Margin="0,0,6,0"/>
                            <ComboBox x:Name="CutPatternComboBox" Width="140"/>
                        </StackPanel>
                        <CheckBox x:Name="CutOverrideWeight" Content="Override Weight" IsChecked="True"/>
                        <StackPanel x:Name="CutWeightRow" Orientation="Horizontal" Margin="12,2,0,2">
                            <TextBlock Text="Weight:" Style="{StaticResource LabelText}" Margin="0,0,6,0"/>
                            <ComboBox x:Name="CutWeight" Width="60"/>
                        </StackPanel>
                        <CheckBox x:Name="CutOverrideColor" Content="Override Color" IsChecked="True"/>
                        <Grid x:Name="CutColorRow" Margin="12,2,0,2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="36"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="R" Style="{StaticResource LabelText}" Margin="0,0,4,2"/>
                            <Slider Grid.Row="0" Grid.Column="1" x:Name="CutR" Margin="0,0,6,2"/>
                            <TextBox Grid.Row="0" Grid.Column="2" x:Name="CutRVal" Style="{StaticResource ValueBox}" Margin="0,0,0,2"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="G" Style="{StaticResource LabelText}" Margin="0,0,4,2"/>
                            <Slider Grid.Row="1" Grid.Column="1" x:Name="CutG" Margin="0,0,6,2"/>
                            <TextBox Grid.Row="1" Grid.Column="2" x:Name="CutGVal" Style="{StaticResource ValueBox}" Margin="0,0,0,2"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="B" Style="{StaticResource LabelText}" Margin="0,0,4,2"/>
                            <Slider Grid.Row="2" Grid.Column="1" x:Name="CutB" Margin="0,0,6,2"/>
                            <TextBox Grid.Row="2" Grid.Column="2" x:Name="CutBVal" Style="{StaticResource ValueBox}" Margin="0,0,0,2"/>
                            <Grid Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,2,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border x:Name="CutPreview" Grid.Column="0" Height="20" BorderBrush="#555555" BorderThickness="1" Background="#000000"/>
                                <Button Grid.Column="1" x:Name="CutPaletteButton" Style="{StaticResource BtnPalette}" Margin="4,0,0,0" Content="&#x1F3A8;" ToolTip="Pick from palette"/>
                            </Grid>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <!-- Surface Foreground -->
            <GroupBox Grid.Row="3" Header="Surface Foreground">
                <StackPanel>
                    <CheckBox x:Name="SurfFgEnabled" Content="Enable Surface FG Override" IsChecked="True"/>
                    <StackPanel x:Name="SurfFgControls" Margin="12,4,0,0">
                        <CheckBox x:Name="SurfFgOverridePattern" Content="Override Pattern" IsChecked="True"/>
                        <Border x:Name="SurfFgPatternDimmer" Margin="0,0,0,2">
                            <TextBlock Text="(uses shared Fill Pattern above)" Style="{StaticResource LabelText}" FontStyle="Italic" Margin="12,2,0,2"/>
                        </Border>
                        <CheckBox x:Name="SurfFgOverrideColor" Content="Override Color" IsChecked="True"/>
                        <Grid x:Name="SurfFgColorRow" Margin="12,2,0,2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="36"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="R" Style="{StaticResource LabelText}" Margin="0,0,4,2"/>
                            <Slider Grid.Row="0" Grid.Column="1" x:Name="SurfFgR" Margin="0,0,6,2"/>
                            <TextBox Grid.Row="0" Grid.Column="2" x:Name="SurfFgRVal" Style="{StaticResource ValueBox}" Margin="0,0,0,2"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="G" Style="{StaticResource LabelText}" Margin="0,0,4,2"/>
                            <Slider Grid.Row="1" Grid.Column="1" x:Name="SurfFgG" Margin="0,0,6,2"/>
                            <TextBox Grid.Row="1" Grid.Column="2" x:Name="SurfFgGVal" Style="{StaticResource ValueBox}" Margin="0,0,0,2"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="B" Style="{StaticResource LabelText}" Margin="0,0,4,2"/>
                            <Slider Grid.Row="2" Grid.Column="1" x:Name="SurfFgB" Margin="0,0,6,2"/>
                            <TextBox Grid.Row="2" Grid.Column="2" x:Name="SurfFgBVal" Style="{StaticResource ValueBox}" Margin="0,0,0,2"/>
                            <Grid Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,2,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border x:Name="SurfFgPreview" Grid.Column="0" Height="20" BorderBrush="#555555" BorderThickness="1" Background="#808080"/>
                                <Button Grid.Column="1" x:Name="SurfFgPaletteButton" Style="{StaticResource BtnPalette}" Margin="4,0,0,0" Content="&#x1F3A8;" ToolTip="Pick from palette"/>
                            </Grid>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <!-- Surface Background -->
            <GroupBox Grid.Row="4" Header="Surface Background">
                <StackPanel>
                    <CheckBox x:Name="SurfBgEnabled" Content="Enable Surface BG Override" IsChecked="True"/>
                    <StackPanel x:Name="SurfBgControls" Margin="12,4,0,0">
                        <CheckBox x:Name="SurfBgOverridePattern" Content="Override Pattern" IsChecked="True"/>
                        <Border x:Name="SurfBgPatternDimmer" Margin="0,0,0,2">
                            <TextBlock Text="(uses shared Fill Pattern above)" Style="{StaticResource LabelText}" FontStyle="Italic" Margin="12,2,0,2"/>
                        </Border>
                        <CheckBox x:Name="SurfBgOverrideColor" Content="Override Color" IsChecked="True"/>
                        <Grid x:Name="SurfBgColorRow" Margin="12,2,0,2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="36"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="R" Style="{StaticResource LabelText}" Margin="0,0,4,2"/>
                            <Slider Grid.Row="0" Grid.Column="1" x:Name="SurfBgR" Margin="0,0,6,2"/>
                            <TextBox Grid.Row="0" Grid.Column="2" x:Name="SurfBgRVal" Style="{StaticResource ValueBox}" Margin="0,0,0,2"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="G" Style="{StaticResource LabelText}" Margin="0,0,4,2"/>
                            <Slider Grid.Row="1" Grid.Column="1" x:Name="SurfBgG" Margin="0,0,6,2"/>
                            <TextBox Grid.Row="1" Grid.Column="2" x:Name="SurfBgGVal" Style="{StaticResource ValueBox}" Margin="0,0,0,2"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="B" Style="{StaticResource LabelText}" Margin="0,0,4,2"/>
                            <Slider Grid.Row="2" Grid.Column="1" x:Name="SurfBgB" Margin="0,0,6,2"/>
                            <TextBox Grid.Row="2" Grid.Column="2" x:Name="SurfBgBVal" Style="{StaticResource ValueBox}" Margin="0,0,0,2"/>
                            <Grid Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,2,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border x:Name="SurfBgPreview" Grid.Column="0" Height="20" BorderBrush="#555555" BorderThickness="1" Background="#B4B4B4"/>
                                <Button Grid.Column="1" x:Name="SurfBgPaletteButton" Style="{StaticResource BtnPalette}" Margin="4,0,0,0" Content="&#x1F3A8;" ToolTip="Pick from palette"/>
                            </Grid>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <!-- Spacer -->
            <Grid Grid.Row="5"/>

            <!-- Footer buttons -->
            <Border Grid.Row="6" BorderBrush="#444444" BorderThickness="0,1,0,0" Padding="0,8,0,0" Margin="0,8,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="CancelButton" Content="Cancel" Style="{StaticResource BtnSecondary}" Margin="0,0,8,0"/>
                    <Button x:Name="OkButton" Content="OK" Style="{StaticResource BtnPrimary}"/>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Window>
