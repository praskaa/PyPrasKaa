<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Load Plan Manager — PrasKaa Tools"
        Width="960" Height="680"
        MinWidth="800" MinHeight="560"
        WindowStartupLocation="CenterScreen"
        Background="#0D1117"
        FontFamily="Segoe UI">

    <Window.Resources>
        <!-- COLORS via brushes for reuse -->
        <SolidColorBrush x:Key="BgBase"        Color="#0D1117"/>
        <SolidColorBrush x:Key="BgSurface"     Color="#161B27"/>
        <SolidColorBrush x:Key="BgCard"        Color="#1C2333"/>
        <SolidColorBrush x:Key="BgInput"       Color="#1C2333"/>
        <SolidColorBrush x:Key="BorderColor"   Color="#30363D"/>
        <SolidColorBrush x:Key="AccentBlue"    Color="#2F81F7"/>
        <SolidColorBrush x:Key="AccentGreen"   Color="#2EA043"/>
        <SolidColorBrush x:Key="AccentOrange"  Color="#F0883E"/>
        <SolidColorBrush x:Key="AccentPurple"  Color="#8B5CF6"/>
        <SolidColorBrush x:Key="TextPrimary"   Color="#E6EDF3"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#7D8590"/>
        <SolidColorBrush x:Key="TextMuted"     Color="#484F58"/>

        <!-- NAV RADIO BUTTON STYLE -->
        <Style x:Key="NavBtn" TargetType="RadioButton">
            <Setter Property="Foreground"            Value="#7D8590"/>
            <Setter Property="Background"            Value="Transparent"/>
            <Setter Property="BorderThickness"       Value="0"/>
            <Setter Property="Padding"               Value="14,10"/>
            <Setter Property="Cursor"                Value="Hand"/>
            <Setter Property="FontSize"              Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Background="Transparent"
                                CornerRadius="6" Margin="4,1"
                                Padding="{TemplateBinding Padding}">
                            <DockPanel>
                                <Border x:Name="Indicator" DockPanel.Dock="Left"
                                        Width="3" CornerRadius="2"
                                        Background="Transparent" Margin="0,0,10,0"/>
                                <ContentPresenter VerticalAlignment="Center"/>
                            </DockPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd"        Property="Background" Value="#1C2333"/>
                                <Setter TargetName="Indicator" Property="Background" Value="#2F81F7"/>
                                <Setter                        Property="Foreground" Value="#E6EDF3"/>
                                <Setter                        Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1C2333"/>
                                <Setter                  Property="Foreground" Value="#E6EDF3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- PRIMARY BUTTON (blue) -->
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Foreground"      Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="18,9"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="#2F81F7"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#388BFD"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1A6ED4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- SUCCESS BUTTON (green) -->
        <Style x:Key="BtnSuccess" TargetType="Button">
            <Setter Property="Foreground"      Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="18,9"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="#2EA043"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3FB950"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#238636"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- GHOST BUTTON (outline) -->
        <Style x:Key="BtnGhost" TargetType="Button">
            <Setter Property="Foreground"      Value="#C9D1D9"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="18,9"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="#21262D"
                                BorderBrush="#30363D" BorderThickness="1"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"   Value="#30363D"/>
                                <Setter TargetName="Bd" Property="BorderBrush"  Value="#58A6FF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3D444D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- WARN BUTTON (orange) -->
        <Style x:Key="BtnWarn" TargetType="Button">
            <Setter Property="Foreground"      Value="#0D1117"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="18,9"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="#F0883E"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E3711A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#C85E0F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- PURPLE BUTTON -->
        <Style x:Key="BtnPurple" TargetType="Button">
            <Setter Property="Foreground"      Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="18,9"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="#8B5CF6"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#7C3AED"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#6D28D9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TEXT INPUT -->
        <Style x:Key="TxtInput" TargetType="TextBox">
            <Setter Property="Background"      Value="#0D1117"/>
            <Setter Property="Foreground"      Value="#7D8590"/>
            <Setter Property="BorderBrush"     Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="10,8"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontFamily"      Value="Consolas"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer Margin="{TemplateBinding Padding}"
                                          x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- COMBOBOX STYLE -->
        <Style TargetType="ComboBox">
            <Setter Property="Foreground"      Value="#E6EDF3"/>
            <Setter Property="Background"      Value="#0D1117"/>
            <Setter Property="BorderBrush"     Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="10,8"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay,
                                                      RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Bd"
                                                Background="#0D1117"
                                                BorderBrush="#30363D"
                                                BorderThickness="1"
                                                CornerRadius="6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="26"/>
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Grid.Column="0"
                                                                  Margin="10,8,0,8"
                                                                  VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="▾"
                                                           Foreground="#7D8590"
                                                           FontSize="10"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="BorderBrush" Value="#58A6FF"/>
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Bd" Property="BorderBrush" Value="#2F81F7"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <ContentPresenter x:Name="ContentSite"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="10,0,30,0"
                                              VerticalAlignment="Center"/>

                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Grid x:Name="DropDown"
                                      SnapsToDevicePixels="True"
                                      MinWidth="{TemplateBinding ActualWidth}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder"
                                            Background="#1C2333"
                                            BorderBrush="#30363D"
                                            BorderThickness="1"
                                            CornerRadius="6">
                                        <ScrollViewer SnapsToDevicePixels="True">
                                            <StackPanel IsItemsHost="True"/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground"  Value="#E6EDF3"/>
            <Setter Property="Background"  Value="Transparent"/>
            <Setter Property="Padding"     Value="10,8"/>
            <Setter Property="FontSize"    Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2F81F7"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1A3A5C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- LABEL -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="#7D8590"/>
            <Setter Property="FontSize"    Value="11"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Margin"      Value="0,0,0,6"/>
        </Style>

        <!-- SECTION TITLE -->
        <Style x:Key="PageTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E6EDF3"/>
            <Setter Property="FontSize"   Value="20"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- PAGE SUBTITLE -->
        <Style x:Key="PageSub" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#7D8590"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Margin"     Value="0,4,0,0"/>
        </Style>

        <!-- DATAGRID COLUMN HEADER -->
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"    Value="#161B27"/>
            <Setter Property="Foreground"    Value="#7D8590"/>
            <Setter Property="FontSize"      Value="11"/>
            <Setter Property="FontWeight"    Value="SemiBold"/>
            <Setter Property="Padding"       Value="12,10"/>
            <Setter Property="BorderBrush"   Value="#30363D"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>

        <!-- DATAGRID ROW -->
        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1C2333"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1A3A5C"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- DATAGRID CELL -->
        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush"     Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                </Trigger>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="Transparent"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- INFO CARD -->
        <Style x:Key="InfoCard" TargetType="Border">
            <Setter Property="Background"      Value="#161B27"/>
            <Setter Property="BorderBrush"     Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="16,14"/>
        </Style>

        <!-- RADIO (export mode) -->
        <Style x:Key="RadioOpt" TargetType="RadioButton">
            <Setter Property="Foreground"  Value="#C9D1D9"/>
            <Setter Property="FontSize"    Value="13"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Setter Property="Margin"      Value="0,0,24,0"/>
        </Style>

        <!-- SLIDER STYLE -->
        <Style TargetType="Slider">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Background="#2F81F7" BorderThickness="0" Height="4"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Background="#30363D" BorderThickness="0" Height="4"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="16" Height="16" Cursor="Hand">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Fill="#2F81F7" Width="16" Height="16"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="210"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════════
             SIDEBAR
        ════════════════════════════════════════════ -->
        <Border Grid.Column="0"
                Background="#161B27"
                BorderBrush="#30363D"
                BorderThickness="0,0,1,0">
            <DockPanel>

                <!-- LOGO / APP BRAND -->
                <Border DockPanel.Dock="Top" Padding="18,20,18,16">
                    <StackPanel>
                        <TextBlock Text="LOAD PLAN"
                                   Foreground="#2F81F7"
                                   FontSize="14" FontWeight="Bold"/>
                        <TextBlock Text="MANAGER"
                                   Foreground="#E6EDF3"
                                   FontSize="14" FontWeight="Bold"/>
                        <TextBlock Text="by PrasKaa"
                                   Foreground="#484F58"
                                   FontSize="11" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- DIVIDER -->
                <Border DockPanel.Dock="Top" Height="1"
                        Background="#30363D" Margin="12,0"/>

                <!-- NAV LINKS -->
                <StackPanel DockPanel.Dock="Top" Margin="10,16,10,0">
                    <TextBlock Text="MENU"
                               Foreground="#484F58"
                               FontSize="10" FontWeight="Bold"
                               Margin="14,0,0,8"/>

                    <RadioButton x:Name="NavAreas"
                                 Style="{StaticResource NavBtn}"
                                 IsChecked="True">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📋" FontSize="14" Margin="0,0,8,0"/>
                            <TextBlock Text="Area Overview"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton x:Name="NavCreate"
                                 Style="{StaticResource NavBtn}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="➕" FontSize="14" Margin="0,0,8,0"/>
                            <TextBlock Text="Create Areas"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton x:Name="NavSetLoads"
                                 Style="{StaticResource NavBtn}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚖️" FontSize="14" Margin="0,0,8,0"/>
                            <TextBlock Text="Set SDL &amp; LL"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton x:Name="NavExport"
                                 Style="{StaticResource NavBtn}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📤" FontSize="14" Margin="0,0,8,0"/>
                            <TextBlock Text="Export Colors"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton x:Name="NavRandomize"
                                 Style="{StaticResource NavBtn}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🎨" FontSize="14" Margin="0,0,8,0"/>
                            <TextBlock Text="Randomize Colors"/>
                        </StackPanel>
                    </RadioButton>
                </StackPanel>

                <!-- BOTTOM VERSION -->
                <Border DockPanel.Dock="Bottom" Padding="18,14">
                    <TextBlock Text="v1.0"
                               Foreground="#484F58"
                               FontSize="11"/>
                </Border>
            </DockPanel>
        </Border>

        <!-- ═══════════════════════════════════════════
             MAIN CONTENT
        ════════════════════════════════════════════ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="40"/>
            </Grid.RowDefinitions>

            <!-- ─── PAGE: AREA OVERVIEW ─── -->
            <Border x:Name="PageAreas" Grid.Row="0"
                    Padding="28,24" Visibility="Visible">
                <DockPanel>

                    <!-- Header -->
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Area Overview"
                                       Style="{StaticResource PageTitle}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal"
                                    VerticalAlignment="Bottom">
                            <TextBlock x:Name="TxtAreaCount"
                                       Foreground="#7D8590" FontSize="12"
                                       VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <Button x:Name="BtnSyncNumbers"
                                    Content="# Sync Numbers"
                                    Style="{StaticResource BtnSuccess}"
                                    ToolTip="Sinkronkan nomor area berdasarkan urutan nama"
                                    Margin="0,0,8,0"/>
                            <Button x:Name="BtnRefresh"
                                    Content="↺ Refresh"
                                    Style="{StaticResource BtnGhost}"
                                    ToolTip="Reload data from Revit"/>
                        </StackPanel>
                    </Grid>

                    <!-- DataGrid -->
                    <DataGrid x:Name="GridAreas"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserResizeRows="False"
                              CanUserReorderColumns="False"
                              HeadersVisibility="Column"
                              SelectionUnit="FullRow"
                              SelectionMode="Single"
                              Background="#0D1117"
                              Foreground="#C9D1D9"
                              BorderBrush="#30363D"
                              BorderThickness="1"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#21262D"
                              RowBackground="Transparent"
                              AlternatingRowBackground="#0F1419"
                              ColumnHeaderHeight="38"
                              RowHeight="40"
                              FontSize="13">
                        <DataGrid.Columns>

                            <!-- COLOR SWATCH -->
                            <DataGridTemplateColumn Header="COLOR" Width="72" CanUserResize="False">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Width="24" Height="24"
                                                Background="{Binding ColorHex}"
                                                CornerRadius="4"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center">
                                            <Border.Effect>
                                                <DropShadowEffect Color="Black" BlurRadius="4"
                                                                  ShadowDepth="1" Opacity="0.4"/>
                                            </Border.Effect>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="AREA NAME"
                                               Binding="{Binding Name}"
                                               Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#E6EDF3"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Padding" Value="12,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="HEX CODE"
                                               Binding="{Binding ColorHex}"
                                               Width="110">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#7D8590"/>
                                        <Setter Property="FontFamily" Value="Consolas"/>
                                        <Setter Property="FontSize"   Value="12"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Padding" Value="12,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="SDL (kN/m²)"
                                               Binding="{Binding SDL}"
                                               Width="115">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground"       Value="#58A6FF"/>
                                        <Setter Property="FontFamily"       Value="Consolas"/>
                                        <Setter Property="FontSize"         Value="13"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="Padding"          Value="0,0,16,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="LL (kN/m²)"
                                               Binding="{Binding LL}"
                                               Width="115">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground"       Value="#3FB950"/>
                                        <Setter Property="FontFamily"       Value="Consolas"/>
                                        <Setter Property="FontSize"         Value="13"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="Padding"          Value="0,0,16,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <!-- ─── PAGE: CREATE AREAS ─── -->
            <Border x:Name="PageCreate" Grid.Row="0"
                    Padding="28,24" Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel MaxWidth="640">

                        <TextBlock Text="Create Areas from CSV"
                                   Style="{StaticResource PageTitle}"/>

                        <!-- Step 1 -->
                        <Border Style="{StaticResource InfoCard}" CornerRadius="8" Margin="0,0,0,16">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <Border Width="24" Height="24" CornerRadius="12"
                                            Background="#2F81F7" Margin="0,0,10,0">
                                        <TextBlock Text="1" Foreground="White"
                                                   FontWeight="Bold" FontSize="12"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Select CSV File"
                                               Foreground="#E6EDF3"
                                               FontSize="14" FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                </StackPanel>

                                <TextBlock Style="{StaticResource FieldLabel}"
                                           Text="CSV FILE  (Column 1 = Area Name)"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="TxtCreateCsv"
                                             Grid.Column="0"
                                             Style="{StaticResource TxtInput}"
                                             IsReadOnly="True"
                                             Text="No file selected..."
                                             ToolTip="Path to the CSV file containing area names"/>
                                    <Button x:Name="BtnBrowseCreate"
                                            Grid.Column="1"
                                            Content="Browse..."
                                            Style="{StaticResource BtnGhost}"
                                            Margin="8,0,0,0"
                                            ToolTip="Select CSV file from explorer"/>
                                </Grid>

                                <Border Background="#0D1117" CornerRadius="6"
                                        Padding="12,10" Margin="0,10,0,0"
                                        BorderBrush="#30363D" BorderThickness="1">
                                    <TextBlock x:Name="TxtCreatePreview"
                                               Foreground="#7D8590"
                                               FontSize="12" FontFamily="Consolas"
                                               TextWrapping="Wrap"
                                               Text="Area preview will appear here after file is selected"/>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Step 2 -->
                        <Border Style="{StaticResource InfoCard}" CornerRadius="8" Margin="0,0,0,24">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <Border Width="24" Height="24" CornerRadius="12"
                                            Background="#2F81F7" Margin="0,0,10,0">
                                        <TextBlock Text="2" Foreground="White"
                                                   FontWeight="Bold" FontSize="12"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Select Target Area Plan View"
                                               Foreground="#E6EDF3"
                                               FontSize="14" FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                </StackPanel>

                                <TextBlock Style="{StaticResource FieldLabel}"
                                           Text="TARGET AREA PLAN VIEW"/>
                                <ComboBox x:Name="CmbViewCreate"
                                          ToolTip="View where areas will be created"/>
                            </StackPanel>
                        </Border>

                        <Button x:Name="BtnCreateAreas"
                                Content="✓  Create Areas"
                                Style="{StaticResource BtnSuccess}"
                                HorizontalAlignment="Left"
                                ToolTip="Create areas from CSV into the selected view"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ─── PAGE: SET SDL & LL ─── -->
            <Border x:Name="PageSetLoads" Grid.Row="0"
                    Padding="28,24" Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel MaxWidth="640">

                        <TextBlock Text="Set SDL dan LL"
                                   Style="{StaticResource PageTitle}"/>

                        <!-- Format info -->
                        <Border Style="{StaticResource InfoCard}" CornerRadius="8" Margin="0,0,0,16"
                                BorderBrush="#1A3A5C">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="ℹ" Foreground="#58A6FF"
                                               FontSize="14" Margin="0,0,8,0"/>
                                    <TextBlock Text="EXPECTED CSV FORMAT"
                                               Foreground="#58A6FF"
                                               FontSize="11" FontWeight="Bold"/>
                                </StackPanel>
                                <Border Background="#0D1117" CornerRadius="6"
                                        Padding="12,10" BorderBrush="#30363D" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="Name , SDL , LL"
                                                   Foreground="#3FB950"
                                                   FontFamily="Consolas" FontSize="13"
                                                   Margin="0,0,0,4"/>
                                        <TextBlock Text="ABC  , 10  , 30"
                                                   Foreground="#7D8590"
                                                   FontFamily="Consolas" FontSize="12"/>
                                        <TextBlock Text="DEF  , 100 , 10"
                                                   Foreground="#7D8590"
                                                   FontFamily="Consolas" FontSize="12"/>
                                    </StackPanel>
                                </Border>
                                <TextBlock Text="Row 1 is treated as a header and skipped automatically."
                                           Foreground="#7D8590" FontSize="11" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- File picker -->
                        <Border Style="{StaticResource InfoCard}" CornerRadius="8" Margin="0,0,0,24">
                            <StackPanel>
                                <TextBlock Style="{StaticResource FieldLabel}"
                                           Text="LOAD CSV FILE"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="TxtLoadsCsv"
                                             Grid.Column="0"
                                             Style="{StaticResource TxtInput}"
                                             IsReadOnly="True"
                                             Text="No file selected..."
                                             ToolTip="File CSV berisi Name, SDL, LL"/>
                                    <Button x:Name="BtnBrowseLoads"
                                            Grid.Column="1"
                                            Content="Browse..."
                                            Style="{StaticResource BtnGhost}"
                                            Margin="8,0,0,0"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Button x:Name="BtnSetLoads"
                                Content="⚖  Update SDL &amp; LL"
                                Style="{StaticResource BtnWarn}"
                                HorizontalAlignment="Left"
                                ToolTip="Apply SDL and LL values from CSV to Revit areas"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ─── PAGE: EXPORT COLORS ─── -->
            <Border x:Name="PageExport" Grid.Row="0"
                    Padding="28,24" Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel MaxWidth="640">

                        <TextBlock Text="Export Warna ke CSV"
                                   Style="{StaticResource PageTitle}"/>

                        <!-- Mode selector -->
                        <Border Style="{StaticResource InfoCard}" CornerRadius="8" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Style="{StaticResource FieldLabel}"
                                           Text="EXPORT MODE"/>
                                <StackPanel Orientation="Horizontal">
                                    <RadioButton x:Name="RbNewCsv"
                                                 Content="Create new CSV"
                                                 IsChecked="True"
                                                 Style="{StaticResource RadioOpt}"/>
                                    <RadioButton x:Name="RbUpdateCsv"
                                                 Content="Update existing CSV"
                                                 Style="{StaticResource RadioOpt}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Existing CSV (conditional) -->
                        <Border x:Name="PanelExistingCsv"
                                Style="{StaticResource InfoCard}" CornerRadius="8"
                                Visibility="Collapsed" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Style="{StaticResource FieldLabel}"
                                           Text="EXISTING CSV FILE"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="TxtExistingCsv"
                                             Grid.Column="0"
                                             Style="{StaticResource TxtInput}"
                                             IsReadOnly="True"
                                             Text="No file selected..."/>
                                    <Button x:Name="BtnBrowseExisting"
                                            Grid.Column="1"
                                            Content="Browse..."
                                            Style="{StaticResource BtnGhost}"
                                            Margin="8,0,0,0"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Output format info -->
                        <Border Style="{StaticResource InfoCard}" CornerRadius="8"
                                Margin="0,0,0,24" BorderBrush="#1A3A2A">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="📄" FontSize="13" Margin="0,0,8,0"/>
                                    <TextBlock Text="FORMAT OUTPUT"
                                               Foreground="#3FB950"
                                               FontSize="11" FontWeight="Bold"/>
                                </StackPanel>
                                <TextBlock Text="Name  |  SDL  |  LL  |  Color (HEX)"
                                           Foreground="#3FB950"
                                           FontFamily="Consolas" FontSize="13"/>
                                <TextBlock Text="SDL and LL are read from Area parameters in the project."
                                           Foreground="#7D8590" FontSize="11" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>

                        <Button x:Name="BtnExport"
                                Content="📤  Export to CSV"
                                Style="{StaticResource BtnSuccess}"
                                HorizontalAlignment="Left"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ─── PAGE: RANDOMIZE ─── -->
            <Border x:Name="PageRandomize" Grid.Row="0"
                    Padding="28,24" Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel MaxWidth="640">

                        <TextBlock Text="Randomize Colors"
                                   Style="{StaticResource PageTitle}"/>

                        <!-- Algorithm explanation -->
                        <Border Style="{StaticResource InfoCard}" CornerRadius="8"
                                Margin="0,0,0,20"
                                BorderBrush="#2D1F5E">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBlock Text="🔬" FontSize="14" Margin="0,0,8,0"/>
                                    <TextBlock Text="ALGORITHM: CIELAB PERCEPTUAL MAXMIN"
                                               Foreground="#A5B4FC"
                                               FontSize="11" FontWeight="Bold"/>
                                </StackPanel>
                                <TextBlock TextWrapping="Wrap"
                                           Foreground="#C4B5FD"
                                           FontSize="12"
                                           LineHeight="20">
                                    Converts RGB → XYZ → CIELAB, then maximizes the minimum
                                    perceptual distance (ΔE) between generated colors.
                                    Result: visually distinct colors easy to tell apart at a glance.
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- Slider -->
                        <Border Style="{StaticResource InfoCard}" CornerRadius="8" Margin="0,0,0,24">
                            <StackPanel>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Style="{StaticResource FieldLabel}"
                                               Text="CANDIDATE SAMPLES"
                                               VerticalAlignment="Center"/>
                                    <Border Grid.Column="1"
                                            Background="#0D1117"
                                            CornerRadius="6" Padding="10,4"
                                            BorderBrush="#30363D" BorderThickness="1">
                                        <TextBlock x:Name="TxtCandidateVal"
                                                   Text="200"
                                                   Foreground="#2F81F7"
                                                   FontWeight="Bold" FontSize="16"
                                                   FontFamily="Consolas"
                                                   HorizontalAlignment="Center"/>
                                    </Border>
                                </Grid>

                                <Slider x:Name="SliderCandidates"
                                        Minimum="50" Maximum="500" Value="200"
                                        TickFrequency="50"
                                        IsSnapToTickEnabled="True"
                                        Margin="0,0,0,8"/>

                                <Grid>
                                    <TextBlock Text="50  (fast)"
                                               Foreground="#484F58" FontSize="11"
                                               HorizontalAlignment="Left"/>
                                    <TextBlock Text="500  (accurate)"
                                               Foreground="#484F58" FontSize="11"
                                               HorizontalAlignment="Right"/>
                                </Grid>

                                <TextBlock Text="Higher values produce more distinct colors but take longer to process."
                                           Foreground="#7D8590" FontSize="11"
                                           TextWrapping="Wrap" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>

                        <Button x:Name="BtnRandomize"
                                Content="🎨  Generate &amp; Apply Colors"
                                Style="{StaticResource BtnPurple}"
                                HorizontalAlignment="Left"
                                ToolTip="Generate new CIELAB colors and apply to Color Fill Scheme"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ═══ STATUS BAR ═══ -->
            <Border Grid.Row="1"
                    Background="#161B27"
                    BorderBrush="#30363D"
                    BorderThickness="0,1,0,0"
                    Padding="18,0">
                <DockPanel VerticalAlignment="Center">
                    <Ellipse x:Name="StatusDot"
                             Width="8" Height="8"
                             Fill="#3FB950"
                             VerticalAlignment="Center"
                             Margin="0,0,8,0"/>
                    <TextBlock x:Name="TxtStatus"
                               Text="Ready"
                               Foreground="#7D8590"
                               FontSize="12"
                               VerticalAlignment="Center"/>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
