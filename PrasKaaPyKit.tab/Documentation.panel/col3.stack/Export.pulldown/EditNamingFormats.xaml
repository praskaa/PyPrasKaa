<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterScreen"
        HorizontalContentAlignment="Center"
        ResizeMode="CanResizeWithGrip" SizeToContent="Height" Width="950" MinHeight="500"
        Title="Export Naming Formats" Closing="cancelled">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <Style x:Key="FormatterTextBox" TargetType="{x:Type TextBox}">
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Margin" Value="0,5,0,0" />
            <Setter Property="Padding" Value="5,0,5,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding builtin}" Value="True">
                    <Setter Property="IsReadOnly" Value="True" />
                    <Setter Property="IsEnabled" Value="False" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="SectionLabel" TargetType="{x:Type TextBlock}">
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Margin" Value="0,0,0,0" />
        </Style>
        <Style x:Key="HintLabel" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="DimGray" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,2,0,4" />
        </Style>
        <Style x:Key="SettingComboBox" TargetType="{x:Type ComboBox}">
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="5,0,5,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,0,0" />
        </Style>
    </Window.Resources>
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition MinWidth="200" Width="1*" />
            <ColumnDefinition Width="4" />
            <ColumnDefinition MinWidth="450" Width="2*" />
        </Grid.ColumnDefinitions>

        <!-- LEFT COLUMN: Format list + printer config -->
        <DockPanel Grid.Column="0" Margin="0,0,5,0">
            <TextBlock Text="Naming Formats" FontWeight="Medium" DockPanel.Dock="Top" />
            <Button Content="Save" Height="30" Margin="0,5,0,0" Click="save_formats" DockPanel.Dock="Bottom"/>
            <Grid DockPanel.Dock="Bottom" Margin="0,5,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="Set Active" Height="30" Margin="0,0,2,0" Click="set_active_format"/>
                <Button Grid.Column="1" Content="Duplicate" Height="30" Margin="0,0,2,0" Click="duplicate_namingformat"/>
                <Button Grid.Column="2" Content="Delete" Height="30" Margin="0,0,0,0" Click="delete_namingformat"/>
            </Grid>

            <!-- PRINTER SECTION -->
            <StackPanel DockPanel.Dock="Bottom" Margin="0,10,0,0">
                <Separator Margin="0,0,0,8" />
                <TextBlock Text="PDF Printer" Style="{StaticResource SectionLabel}" />
                <TextBlock Text="Printer yang digunakan saat export PDF."
                           Style="{StaticResource HintLabel}"/>
                <ComboBox x:Name="printer_cb"
                          Style="{StaticResource SettingComboBox}"
                          SelectionChanged="printer_selection_changed" />
                <TextBlock x:Name="printer_status_tb"
                           Text=""
                           Foreground="#4CAF50"
                           FontSize="11"
                           Margin="0,4,0,0"
                           TextWrapping="Wrap"
                           Visibility="Collapsed"/>
            </StackPanel>

            <ListBox x:Name="formats_lb" FontFamily="Consolas" Margin="0,5,0,0"
                     SelectionChanged="namingformat_changed"
                     SelectionMode="Single" SelectedIndex="0">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding name}" Margin="0,0,5,0"/>
                            <TextBlock Text="✓" FontWeight="Bold" Foreground="Green"
                                       Visibility="{Binding is_active, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>

        <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Width="4" />

        <!-- RIGHT COLUMN: TabControl — Naming Format + DWG Settings -->
        <TabControl Grid.Column="2" Margin="5,0,0,0" BorderThickness="1">

            <!-- TAB 1: Naming Format Editor (tidak berubah) -->
            <TabItem Header="Naming Format">
                <StackPanel x:Name="namingformat_edit" Margin="8,8,0,0">
                    <TextBlock Text="Format Title" FontWeight="Medium" />
                    <TextBlock TextWrapping="Wrap" Foreground="DimGray">
                        This is the name of this specific naming format. Give the format a descriptive
                        name that is easy to understand and find. For example: "Project Standard Format"
                    </TextBlock>
                    <TextBox x:Name="template_name_tb"
                             Text="{Binding name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource FormatterTextBox}"/>

                    <TextBlock Text="Template" FontWeight="Medium" Margin="0,10,0,0" />
                    <TextBlock TextWrapping="Wrap" Foreground="DimGray">
                        This is the actual naming format template. Each "{}" (tag) represents a value that will be
                        filled when creating the file name. Pick and choose from the tags listed
                        below and drag them to this box.
                    </TextBlock>
                    <TextBox x:Name="template_tb"
                             Text="{Binding template, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource FormatterTextBox}"
                             AllowDrop="True" PreviewDrop="stop_drag" PreviewDragOver="preview_drag"/>

                    <TextBlock Text="Drag and drop from formatters below. Hover over the formatter for description"
                               Foreground="DimGray" Margin="0,5,0,0"/>
                    <ItemsControl x:Name="formatters_wp" Margin="0,5,0,0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel IsItemsHost="True" PreviewMouseLeftButtonDown="start_drag"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border x:Name="formatter_box" Height="20" Margin="5,5,0,0"
                                        Background="DarkGray" BorderThickness="0" CornerRadius="5"
                                        ToolTip="{Binding desc}">
                                    <TextBlock Text="{Binding template}" FontFamily="Consolas"
                                               Foreground="White" VerticalAlignment="Center"
                                               Margin="5,0,5,0" Padding="0,0,0,1" />
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding template}" Value="{}{number}">
                                        <Setter TargetName="formatter_box" Property="Background" Value="#4CAF50" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding template}" Value="{}{name}">
                                        <Setter TargetName="formatter_box" Property="Background" Value="#2196F3" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding template}" Value="{}{rev_number}">
                                        <Setter TargetName="formatter_box" Property="Background" Value="#FF9800" />
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </TabItem>

            <!-- TAB 2: DWG Export Settings -->
            <TabItem Header="DWG Settings">
                <StackPanel Margin="8,8,8,8">

                    <!-- Export Setup -->
                    <TextBlock Text="Export Setup" Style="{StaticResource SectionLabel}" />
                    <TextBlock Text="Pilih saved DWG Export Setup dari Revit. Setup mengatur layer mapping, linetype, dll."
                               Style="{StaticResource HintLabel}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="6" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="dwg_exportsetup_cb"
                                  Grid.Column="0"
                                  Style="{StaticResource SettingComboBox}"
                                  SelectionChanged="dwg_setting_changed"/>
                        <Button Grid.Column="2" Content="Refresh" Height="28"
                                Padding="10,0,10,0" Click="dwg_refresh_setups"
                                ToolTip="Reload daftar Export Setup dari Revit"/>
                    </Grid>

                    <Separator Margin="0,12,0,12" />

                    <!-- Merged Views -->
                    <TextBlock Text="Merged Views" Style="{StaticResource SectionLabel}" />
                    <TextBlock Text="Gabungkan semua views dalam satu sheet menjadi satu file DWG."
                               Style="{StaticResource HintLabel}"/>
                    <ComboBox x:Name="dwg_mergedviews_cb"
                              Style="{StaticResource SettingComboBox}"
                              SelectionChanged="dwg_setting_changed">
                        <ComboBoxItem Content="On (Merged)" Tag="True" />
                        <ComboBoxItem Content="Off (Separate)" Tag="False" />
                    </ComboBox>

                    <Separator Margin="0,12,0,12" />

                    <!-- File Format Version -->
                    <TextBlock Text="File Format Version" Style="{StaticResource SectionLabel}" />
                    <TextBlock Text="Versi format file DWG yang digunakan untuk export."
                               Style="{StaticResource HintLabel}"/>
                    <ComboBox x:Name="dwg_fileformat_cb"
                              Style="{StaticResource SettingComboBox}"
                              SelectionChanged="dwg_setting_changed">
                        <ComboBoxItem Content="AutoCAD 2018 (R24)" Tag="R2018" />
                        <ComboBoxItem Content="AutoCAD 2013 (R19)" Tag="R2013" />
                        <ComboBoxItem Content="AutoCAD 2010 (R18)" Tag="R2010" />
                        <ComboBoxItem Content="AutoCAD 2007 (R17)" Tag="R2007" />
                    </ComboBox>

                    <Separator Margin="0,12,0,12" />

                    <!-- Status feedback -->
                    <TextBlock x:Name="dwg_status_tb"
                               Text=""
                               Foreground="#4CAF50"
                               FontSize="11"
                               TextWrapping="Wrap"
                               Visibility="Collapsed"/>
                </StackPanel>
            </TabItem>

        </TabControl>
    </Grid>
</Window>
